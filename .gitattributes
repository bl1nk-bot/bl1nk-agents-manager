# .gitattributes

# Normalize text files to LF line endings
* text=auto eol=lf

# Rust source files
*.rs text eol=lf

# Markdown documentation
*.md text eol=lf

# Configuration files
*.toml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Git LFS (if needed in the future)
# *.ppm -f lfs diff lfs merge lfs -text
# *.zip -f lfs diff lfs merge lfs -text

# Documents
*.pdf -text
*.docx -text

# Custom diff for specific file types
*.rs diff=rust
*.md diff=markdown

# Merge strategies
*.rs merge=union
*.toml merge=union

# Ignore changes to specific files in history (like logs)
*.log -diff