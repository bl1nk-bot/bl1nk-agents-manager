{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/billlzzz18/bl1nk-agents-manager/schema/config.json",
  "title": "BL1NK Agents Manager Configuration Schema",
  "description": "Configuration schema for BL1NK Agents Manager - supports TOML, JSON, and YAML formats",
  "version": "1.0.0",
  "type": "object",
  "definitions": {
    "server_config": {
      "type": "object",
      "description": "Server configuration",
      "properties": {
        "host": {
          "type": "string",
          "description": "Server bind address",
          "default": "127.0.0.1"
        },
        "port": {
          "type": "integer",
          "description": "Server port",
          "minimum": 1,
          "maximum": 65535,
          "default": 3000
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "description": "Maximum concurrent tasks",
          "minimum": 1,
          "default": 5
        }
      },
      "required": ["host", "port"],
      "additionalProperties": false
    },
    "main_agent_config": {
      "type": "object",
      "description": "Main agent configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Main agent name"
        },
        "type": {
          "type": "string",
          "description": "Agent type",
          "enum": ["gemini-cli", "cli", "gemini-extension", "internal"]
        },
        "session_token_path": {
          "type": "string",
          "description": "Path to session token file"
        }
      },
      "required": ["name", "type"],
      "additionalProperties": false
    },
    "rate_limit": {
      "type": "object",
      "description": "Rate limiting configuration",
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "description": "Requests per minute limit",
          "minimum": 1,
          "default": 60
        },
        "requests_per_day": {
          "type": "integer",
          "description": "Requests per day limit",
          "minimum": 1,
          "default": 2000
        }
      },
      "additionalProperties": false
    },
    "agent_config": {
      "type": "object",
      "description": "Agent configuration",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique agent identifier (slug)",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "description": "Display name (3-64 characters)",
          "minLength": 3,
          "maxLength": 64
        },
        "type": {
          "type": "string",
          "description": "Agent type",
          "enum": ["cli", "gemini-extension", "internal"]
        },
        "command": {
          "type": "string",
          "description": "Executable command for CLI agents"
        },
        "args": {
          "type": "array",
          "description": "Command arguments",
          "items": {
            "type": "string"
          }
        },
        "extension_name": {
          "type": "string",
          "description": "Extension name for gemini-extension type"
        },
        "rate_limit": {
          "$ref": "#/definitions/rate_limit"
        },
        "capabilities": {
          "type": "array",
          "description": "Agent capabilities",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "type": "integer",
          "description": "Agent priority (0-255)",
          "minimum": 0,
          "maximum": 255,
          "default": 100
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether agent is enabled",
          "default": true
        },
        "requires": {
          "type": "array",
          "description": "Required capabilities",
          "items": {
            "type": "string"
          }
        },
        "cost": {
          "type": "integer",
          "description": "Agent cost (0=free, <500=cheap, >=500=expensive)",
          "minimum": 0,
          "default": 0
        }
      },
      "required": ["id", "name", "type", "capabilities"],
      "additionalProperties": false
    },
    "routing_tier": {
      "type": "string",
      "description": "Routing tier for priority calculation",
      "enum": ["default", "user", "admin"],
      "default": "default"
    },
    "routing_rule": {
      "type": "object",
      "description": "Routing rule for task matching",
      "properties": {
        "task_type": {
          "type": "string",
          "description": "Task type to match"
        },
        "keywords": {
          "type": "array",
          "description": "Keywords to match in prompt",
          "items": {
            "type": "string"
          }
        },
        "preferred_agents": {
          "type": "array",
          "description": "Preferred agent IDs in priority order",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "type": "integer",
          "description": "Rule priority (0-999)",
          "minimum": 0,
          "maximum": 999,
          "default": 0
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether rule is enabled",
          "default": true
        }
      },
      "required": ["task_type", "preferred_agents"],
      "additionalProperties": false
    },
    "routing_config": {
      "type": "object",
      "description": "Routing configuration",
      "properties": {
        "tier": {
          "$ref": "#/definitions/routing_tier"
        },
        "rules": {
          "type": "array",
          "description": "Routing rules",
          "items": {
            "$ref": "#/definitions/routing_rule"
          }
        }
      },
      "additionalProperties": false
    },
    "rate_limiting_config": {
      "type": "object",
      "description": "Global rate limiting configuration",
      "properties": {
        "strategy": {
          "type": "string",
          "description": "Rate limiting strategy",
          "enum": ["round-robin", "priority", "least-loaded"],
          "default": "round-robin"
        },
        "track_usage": {
          "type": "boolean",
          "description": "Whether to track usage",
          "default": true
        },
        "usage_db_path": {
          "type": "string",
          "description": "Path to usage database"
        }
      },
      "required": ["usage_db_path"],
      "additionalProperties": false
    },
    "logging_config": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "description": "Log level",
          "enum": ["trace", "debug", "info", "warn", "error"],
          "default": "info"
        },
        "output": {
          "type": "string",
          "description": "Log output destination",
          "enum": ["stdout", "stderr", "file"],
          "default": "stdout"
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "server": {
      "$ref": "#/definitions/server_config"
    },
    "main_agent": {
      "$ref": "#/definitions/main_agent_config"
    },
    "agents": {
      "type": "array",
      "description": "List of agent configurations",
      "items": {
        "$ref": "#/definitions/agent_config"
      },
      "minItems": 1
    },
    "routing": {
      "$ref": "#/definitions/routing_config"
    },
    "rate_limiting": {
      "$ref": "#/definitions/rate_limiting_config"
    },
    "logging": {
      "$ref": "#/definitions/logging_config"
    }
  },
  "required": [
    "server",
    "main_agent",
    "agents",
    "routing",
    "rate_limiting"
  ],
  "additionalProperties": false
}
