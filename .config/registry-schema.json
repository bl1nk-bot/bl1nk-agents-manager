{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Registry Schema",
  "description": "สคีมาสำหรับตรวจสอบความถูกต้องของไฟล์ agents.json (Technical Registry)",
  "version": "1.3.0",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "last_updated": { "type": "string", "format": "date-time" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "file": { "type": "string" },
          "type": { 
            "type": "string",
            "enum": ["class", "trans", "code", "plan", "create", "image", "analysis", "docs", "assistant", "general"]
          },
          "model": { "type": "string" },
          "permission": { "type": "integer", "minimum": 0, "maximum": 999 },
          "tools": { 
            "type": "array", 
            "items": { "type": "string" } 
          },
          "tool_permissions": {
            "type": "object",
            "properties": {
              "bash": { "type": "boolean" },
              "write": { "type": "boolean" },
              "skill": { "type": "boolean" },
              "ask": { "type": "boolean" }
            },
            "required": ["bash", "write", "skill", "ask"]
          },
          "permission_policy": { "type": "object" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "color": { "type": "string" }
        },
        "required": ["name", "file", "type", "model", "permission", "tools", "tool_permissions"]
      }
    }
  },
  "required": ["version", "agents"]
}
