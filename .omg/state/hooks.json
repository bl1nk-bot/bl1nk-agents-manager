{
  "enabled": true,
  "profile": "balanced",
  "native_events": ["session-start", "stage-transition", "pre-verify", "post-verify", "checkpoint-save", "blocker-raised", "session-stop"],
  "derived_signals": {"context-drift": true, "risk-spike": true, "loop-stall": true, "token-burst": false, "blocker-repeat": true, "agent-blocked": true, "agent-finished-early": true},
  "lanes": {"P0-safety": {"timeout_ms": 400, "debounce_ms": 0}, "P1-quality": {"timeout_ms": 800, "debounce_ms": 200}, "P2-optimization": {"timeout_ms": 600, "debounce_ms": 500}},
  "lifecycle_policy": {"before_after_symmetry": true, "continuation_reenters_safety_lane": true, "terminal_states": ["completed", "blocked", "stopped"]},
  "team_safety": {"disable_side_effects_for_worker_sessions": true},
  "plugins": {"safety": {"lane": "P0", "enabled": true}, "quality": {"lane": "P1", "enabled": true}, "optimization": {"lane": "P2", "enabled": true}},
  "source": "omg:hooks"
}
