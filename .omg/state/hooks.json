{
  "enabled": true,
  "profile": "balanced",
  "native_events": ["session-start", "stage-transition", "pre-verify", "post-verify", "checkpoint-save", "blocker-raised", "session-stop"],
  "event_lanes": {
    "session-start": "P1-quality",
    "stage-transition": "P1-quality",
    "pre-verify": "P0-safety",
    "post-verify": "P0-safety",
    "checkpoint-save": "P2-optimization",
    "blocker-raised": "P0-safety",
    "session-stop": "P1-quality"
  },
  "derived_signals": {
    "context-drift": { "enabled": true, "lane": "P1-quality" },
    "risk-spike": { "enabled": true, "lane": "P0-safety" },
    "loop-stall": { "enabled": true, "lane": "P1-quality" },
    "token-burst": { "enabled": false, "lane": "P2-optimization" },
    "blocker-repeat": { "enabled": true, "lane": "P0-safety" },
    "agent-blocked": { "enabled": true, "lane": "P0-safety" },
    "agent-finished-early": { "enabled": true, "lane": "P1-quality" }
  },
  "lanes": {
    "P0-safety": { "timeout_ms": 400, "debounce_ms": 0 },
    "P1-quality": { "timeout_ms": 800, "debounce_ms": 200 },
    "P2-optimization": { "timeout_ms": 600, "debounce_ms": 500 }
  },
  "lifecycle_policy": {
    "before_after_symmetry": true,
    "continuation_reenters_safety_lane": true,
    "terminal_states": ["completed", "blocked", "stopped"]
  },
  "team_safety": {
    "disable_side_effects_for_worker_sessions": true,
    "require_confirmation_for": ["P0-safety"]
  },
  "idempotency_key_fields": ["event", "task_id", "session_id"],
  "plugins": {
    "safety": { "lane": "P0", "enabled": true, "priority": 1 },
    "quality": { "lane": "P1", "enabled": true, "priority": 2 },
    "optimization": { "lane": "P2", "enabled": true, "priority": 3 }
  },
  "source": "omg:hooks",
  "last_applied_fixes": "2026-04-12"
}
